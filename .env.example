# Required — JWT signing secret (gunakan string acak panjang minimal 32 karakter)
JWT_SECRET=

# Required — Supabase PostgreSQL connection string
SUPABASE_DATABASE_URL=

# Required — Alibaba Dashscope API key untuk Qwen AI
DASHSCOPE_API_KEY=

# Set otomatis oleh Railway
PORT=8080

# Set ke "production" di Railway
NODE_ENV=production
